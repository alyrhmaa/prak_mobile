<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6">

    <!-- 🔥 APPBAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FF8A65"
            app:title="Dashboard Pertemuan 5"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 🔥 CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 👋 HEADER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, Welcome 👋"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#2D3436"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore fitur WebView di bawah ini"
                android:textSize="14sp"
                android:textColor="#7F8C8D"
                android:layout_marginBottom="20dp"/>

            <!-- 🔷 CARD UTAMA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_home2dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WebView Module"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:gravity="center"
                        android:textColor="#2D3436"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Menampilkan halaman web langsung di dalam aplikasi Android."
                        android:textSize="13sp"
                        android:gravity="center"
                        android:textColor="#636E72"
                        android:layout_marginVertical="10dp"/>

                    <!-- 🔥 BUTTON (WAJIB SAMA ID) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWeb"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Open Web"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#FF7043"
                        app:cornerRadius="14dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🔷 INFO BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFE0B2"
                android:padding="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gunakan WebView untuk membuka halaman tanpa keluar aplikasi."
                    android:textSize="13sp"
                    android:textColor="#E65100"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>